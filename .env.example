# Copy this file to .env and fill in your own values.

# ── Linear ────────────────────────────────────────────────────
# Your webhook signing secret from Linear.
# Where to find it:
#   Linear -> Settings -> API -> Webhooks -> [your webhook] -> Signing Secret
LINEAR_WEBHOOK_SECRET=your_linear_signing_secret_here

# ── Discord ───────────────────────────────────────────────────
# The webhook URL for the Discord channel you want to post to.
# Where to find it:
#   Discord -> Channel Settings -> Integrations -> Webhooks -> Copy Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Server ────────────────────────────────────────────────────
# Port for local development. 
# PORT=3000
